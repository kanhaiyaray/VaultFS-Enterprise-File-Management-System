# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/vaultfs

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# ── Client URL (for CORS + email links) ──────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (nodemailer — use Gmail App Password or SMTP relay) ─────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="VaultFS <noreply@vaultfs.app>"

# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800        # 50 MB in bytes
DEFAULT_STORAGE_LIMIT=5368709120  # 5 GB in bytes

# ── Password Reset ────────────────────────────────────────────────────────────
RESET_TOKEN_EXPIRES_HOURS=2   # hours until reset link expires

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=replace_with_webhook_signing_secret

# ── Branding (optional defaults) ─────────────────────────────────────────────
APP_NAME=VaultFS
APP_PRIMARY_COLOR=#6366f1
